# VCS / CI / editors
.git
.github
.idea
.vscode

# Dependencies & build output (rebuilt inside the image)
node_modules
vendor
public/build
public/hot

# Wayfinder codegen (regenerated during the build)
resources/js/actions
resources/js/routes
resources/js/wayfinder

# Secrets & local env (never bake into the image)
.env
.env.*
!.env.docker.example

# Local SQLite / dev data
database/database.sqlite
database/*.sqlite

# Tests & docs (not needed at runtime)
tests
*.md
docs

# Compose / deployment files
docker-compose*.yml
