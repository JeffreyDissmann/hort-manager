{
	# TLS is terminated upstream (Cloudflare Tunnel) — speak plain HTTP only.
	auto_https off
	admin off
	frankenphp
	order php_server before file_server
}

# Plain HTTP; Cloudflare Tunnel dials this over the internal Docker network.
# X-Forwarded-* (scheme/IP) are honored by Laravel's trustProxies, not here.
:8080 {
	root * /app/public
	encode zstd gzip

	# Let the service worker (served from /build) control the whole origin (scope "/").
	@sw path /build/sw.js
	header @sw Service-Worker-Allowed "/"

	php_server
}
