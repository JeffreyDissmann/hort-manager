{%- comment -%}
  TRMNL private plugin — Screen 1 "HEUTE": today's pickup timeline.
  Paste into the plugin's Markup (Full view). Data comes from the polled
  /trmnl/dashboard feed; fields under `today` (see docs/trmnl/README.md).
{%- endcomment -%}

<div class="view view--full">
  <div class="layout">
    <div class="columns">
      <div class="column">

        <div class="richtext richtext--center">
          <span class="value value--large">{{ today.present_count }}</span>
          <span class="label">Kinder noch da{% if today.next_pickup %} · nächste Abholung {{ today.next_pickup }} Uhr{% endif %}</span>
        </div>

        <table class="table">
          <tbody>
            {% for slot in today.departures %}
              <tr>
                <td class="w--16"><span class="value value--small">{{ slot.time }}</span></td>
                <td>
                  {%- for kid in slot.children -%}
                    <span class="label">
                      {%- if kid.left %}✓ {% endif -%}
                      {{ kid.name }}
                      {%- if kid.alone %} (allein){% endif -%}
                      {%- if kid.excursion %} 🚌{% endif -%}
                    </span>
                    {%- if kid.deviation %}<span class="label label--underline">⚠ {{ kid.deviation }}</span>{% endif -%}
                    {%- unless forloop.last %}<span class="label">·</span>{% endunless -%}
                  {%- endfor -%}
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>

        {% if today.absent.size > 0 %}
          <div class="richtext">
            <span class="label label--underline">Heute nicht da:</span>
            <span class="label label--small">
              {%- for a in today.absent -%}{{ a.name }} ({{ a.reason }}){% unless forloop.last %} · {% endunless %}{%- endfor -%}
            </span>
          </div>
        {% endif %}

        {% if today.program.lunch or today.program.activity or today.program.homework %}
          <div class="flex gap--small">
            {% if today.program.lunch %}<span class="label label--small">🍽 {{ today.program.lunch }}</span>{% endif %}
            {% if today.program.activity %}<span class="label label--small">🎨 {{ today.program.activity }}</span>{% endif %}
            {% if today.program.homework %}<span class="label label--small">📚 {{ today.program.homework }}</span>{% endif %}
          </div>
        {% endif %}

      </div>
    </div>
  </div>

  <div class="title_bar">
    <span class="title">Hort · Heute</span>
    <span class="instance">{{ today.weekday }}, {{ today.date }} · Stand {{ generated_at }}</span>
  </div>
</div>
