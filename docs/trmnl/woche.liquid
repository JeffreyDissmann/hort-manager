{%- comment -%}
  TRMNL private plugin — Screen 2 "DIESE WOCHE": Mo–Fr pickup overview.
  Paste into the plugin's Markup (Full view). Data comes from the polled
  /trmnl/dashboard feed; fields under `week` (see docs/trmnl/README.md).
{%- endcomment -%}

<div class="view view--full">
  <div class="layout">
    <div class="columns">
      {% for day in week %}
        <div class="column">
          <span class="title title--small{% if day.is_today %} label--underline{% endif %}">{{ day.weekday }} {{ day.date }}</span>

          {% if day.excursion %}
            <span class="label label--small">🚌 {{ day.excursion }}</span>
          {% endif %}

          {% for slot in day.departures %}
            <div class="item">
              <div class="meta"><span class="label label--small">{{ slot.time }}</span></div>
              <div class="content">
                <span class="description">{{ slot.names | join: ', ' }}</span>
              </div>
            </div>
          {% endfor %}

          {% unless day.departures.size > 0 or day.excursion %}
            <span class="label label--small">–</span>
          {% endunless %}
        </div>
      {% endfor %}
    </div>
  </div>

  <div class="title_bar">
    <span class="title">Hort · Diese Woche</span>
    <span class="instance">Stand {{ generated_at }}</span>
  </div>
</div>
