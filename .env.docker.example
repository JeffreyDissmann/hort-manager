# Production environment for docker-compose.prod.yml. Copy to `.env` and edit.

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Hort-Manager
APP_ENV=production
APP_DEBUG=false
# Your public Cloudflare hostname. Links inside Slack messages are built from this.
APP_URL=https://hort.example.com
APP_TIMEZONE=Europe/Berlin
APP_LOCALE=de
APP_FALLBACK_LOCALE=de
APP_FAKER_LOCALE=de_DE

# APP_KEY: generate with `php artisan key:generate --show` and paste below, OR
# leave it OUT entirely — the entrypoint generates one and persists it on the
# volume. NEVER leave an empty `APP_KEY=` line: an empty value overrides the
# generated key and 500s every request.
# APP_KEY=

# Logs go to the container's stderr (captured by `docker logs` / your NAS).
LOG_CHANNEL=stderr
LOG_LEVEL=warning

# ── Database — SQLite on the named volume ────────────────────────────────────
DB_CONNECTION=sqlite
DB_DATABASE=/app/storage/app/database/database.sqlite
# WAL + a busy timeout let the web threads, queue and scheduler share the one file.
DB_JOURNAL_MODE=WAL
DB_BUSY_TIMEOUT=5000
DB_SYNCHRONOUS=NORMAL

# ── Queue / cache / session (all SQLite-backed, so persisted with the DB) ─────
QUEUE_CONNECTION=database
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_SECURE_COOKIE=true

# ── Data retention ───────────────────────────────────────────────────────────
DATA_RETENTION_WEEKS=4

# ── Slack (see docs/slack-setup.md) ──────────────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI="${APP_URL}/auth/slack/callback"
SLACK_SIGNING_SECRET=
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_TEAM_ID=
SLACK_WORKSPACE=

# ── Web Push (PWA notifications) ─────────────────────────────────────────────
# Generate once with: docker compose -f docker-compose.prod.yml exec app \
#   php artisan webpush:vapid  (copy the two keys here; don't rotate them).
# VAPID_SUBJECT is a mailto:/URL identifying you — required by Safari/iOS.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:you@example.com"

# ── AI assistant (Ollama) ────────────────────────────────────────────────────
# Powers the Slack chat + /hort command. OLLAMA_URL must be reachable from the
# container — use the Ollama host's IP (mDNS/.local names may not resolve in
# Docker). Leave the default localhost to effectively disable (replies degrade
# gracefully). Also needs Slack: message.im event + im:history scope.
AI_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=ministral-3:8b
# Max seconds for one generation; keeps a slow/hung Ollama from wedging the queue.
OLLAMA_TIMEOUT=30

# ── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Token from Zero Trust → Networks → Tunnels. Point the tunnel's public hostname
# at http://app:8080 in that dashboard.
CLOUDFLARE_TUNNEL_TOKEN=

# ── Optional ─────────────────────────────────────────────────────────────────
# Promote this (already Slack-signed-in) user to admin on boot. Idempotent.
# ADMIN_EMAIL=you@example.com

# Pin a specific image instead of :latest (e.g. a CalVer release tag).
# APP_IMAGE=ghcr.io/jeffreydissmann/hort-manager:2026.06.28
