APP_NAME="Hort-Manager"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_TIMEZONE=Europe/Berlin
APP_LOCALE=de
APP_FALLBACK_LOCALE=de
APP_FAKER_LOCALE=de_DE

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# "Sign in with Slack" SSO — create a Slack app, enable Sign in with Slack,
# add the identity.basic/identity.email/identity.team user scopes, and set the
# redirect URL to APP_URL + /auth/slack/callback.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI="${APP_URL}/auth/slack/callback"
# SLACK_TEAM_ID (the workspace's T… id) does double duty: it pre-selects the
# workspace AND restricts sign-in to members of that workspace (anyone else is
# rejected). SLACK_WORKSPACE is the <workspace>.slack.com subdomain, used to
# skip Slack's "enter your workspace" picker. Leave both blank to allow any
# Slack user and show the picker.
SLACK_TEAM_ID=
SLACK_WORKSPACE=

# Bot token (xoxb-…) for sending Slack DMs (departure alerts, excursion
# announcements/reminders). Add the chat:write bot scope and install the app
# to get it. Left blank, those notifications are simply skipped. The default
# channel is only needed for channel posts (not DMs).
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=

VITE_APP_NAME="${APP_NAME}"
